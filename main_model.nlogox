<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[__includes [ 
  "utils/datetime.nls"
  "utils/distances.nls"
  "utils/events.nls"
  "utils/map_setup.nls"
  "turtles/shars/shar_model.nls" 
  "turtles/carriers/carrier_model.nls" 
  "turtles/frigates/frigates_model.nls"
  "turtles/destroyers/destroyer_model.nls"
  "turtles/amphibs/amphib_model.nls"
  "turtles/flotillas/flotilla_model.nls"
  "turtles/faa/faa_model.nls"
]

;; hi
globals [ 
  ocean-color ocean-offset
  
  current-date-string
  start-time
  cur-min cur-hour cur-day cur-month cur-year
  conflict-days
  event-list
  
  ;; carrier spawn zone
  spawn-patch
  
  ;; using these for plotting
  attacks 
  intercepts 
  failures 
  faa-jets
  faa-losses
  amphibs-landed
  carriers-hit ;; added by grace
  frigates-hit
  destroyers-hit
  amphibs-hit
  
  ;; constants for the shars
  shar-cruise-speed shar-max-speed shar-cruise-burn shar-max-burn shar-vis-range aim9l-range aim9l-pkill
  shar-cap-list
  
  ;; constants for the carriers
  carrier-alert-dist
  shar-launch-int
  
  ;; constants for the FAA
  dagger-max-speed dagger-cruise-speed dagger-range
  skyhawk-max-speed skyhawk-cruise-speed skyhawk-range
  sue-max-speed sue-cruise-speed sue-range
  bomb-range exocet-range
  
] 

;; set up ocean patch
patches-own [ ocean? zone ]   ;; is what zone is it in?

;; setting up the types of turtles <plural name> <singular name>
breed [ carriers carrier ]
breed [ events event ]
breed [ ships ship ] 
breed [ frigates frigate ]
breed [ destroyers destroyer ]
breed [ amphibs amphib ]
breed [ shars shar ]
breed [ daggers dagger ]
breed [ faas faa ]
breed [ flotillas flotilla ]
undirected-link-breed [ target-links target-link ]

;; all turtles have these variables (really coarse-grained inheritance)
turtles-own [ strength state speed waypoints w-i ]

;; only breeds have these variables
daggers-own [ bombs launch aircraft ]  
  

;; initializes everything
to setup
  clear-all
  
  setup-map
  draw-x-limits
  
  show count patches with [ zone = "zone-1" and ocean? ]

  
  ;; initializes global variables
  set ocean-color 96.5
  set ocean-offset 0.5
  set attacks 0
  set intercepts 0
  set failures 0
  set faa-jets 75
  set faa-losses 0
  set amphibs-landed 0
  set carriers-hit 0
  set frigates-hit 0
  set destroyers-hit 0
  set amphibs-hit 0
  
  set cur-min 0
  set cur-hour 0
  set cur-day 21
  set cur-month 5
  set cur-year 1982
  set conflict-days 0
  update-date-string
  
  setup-events
  
  ;; initialize patches
;   ask patches [ set pcolor ocean-color + random-float ocean-offset ]
;   ask patch 0 0 [ set pcolor blue ]
  ask patch (floor nmi-to-patches 200) 0 [ set pcolor red ]
  
  setup-carriers
  setup-flotillas
  setup-frigates
  setup-destroyers
;   setup-amphibs
  setup-shars
  setup-faa-constants
  
  ;; CAP labels
  if show-caps? [
    let i 1
    while [i < length shar-cap-list] [
      let c item i shar-cap-list
      create-turtles 1 [
        setxy (item 0 c) (item 1 c)
        set size 0
        set label word i "    "
      ]
      set i i + 1
    ]
  ]
  
  ;; VERY visible red test marker at 200 nmi reference
  create-turtles 1 [
    setxy (floor nmi-to-patches 200) 0
    set shape "dot"
    set color red
    set size 6
  ]
  
  
  reset-ticks
end

to-report end-condition
  let faa-low? (faa-losses >= 25)
  let amphibs-complete? (amphibs-landed + amphibs-hit >= 25)
  let carrier-hit? (count carriers = 1)

  report (carrier-hit? or (faa-low? and amphibs-complete?))
end

;; this is the core loop that runs all of the turtles' logic each tick
to go
  if end-condition [
    stop
  ]
  advance-time minutes-per-tick
  update-date-string
  check-events
  move-flotillas
  move-amphibs
  move-carriers
  move-frigates
  move-destroyers
  move-shars
  move-faas
  spawn-faa?
  ask carriers [ spawn-shars? ]
  ask frigates [ execute-logic ]
  ask destroyers [ execute-logic-destroyer ]
  tick
end

;; Generic RNG function
to-report RNG [ p ]
  let probability p
  ifelse random-float 1.0 < probability [ report true ][ report false ]
end


]]></code>
  <widgets>
    <view x="425" wrappingAllowedX="false" y="10" frameRate="30.0" minPycor="-100" height="840" showTickCounter="true" patchSize="2.07" fontSize="10" wrappingAllowedY="false" width="1460" tickCounterLabel="ticks" maxPycor="100" updateMode="1" maxPxcor="250" minPxcor="-100"></view>
    <button x="70" y="5" height="40" disableUntilTicks="true" forever="true" kind="Observer" width="55">go</button>
    <switch x="10" y="50" height="40" on="true" variable="show-stat?" width="115" display="show-stat?"></switch>
    <button x="10" y="5" height="40" disableUntilTicks="false" forever="false" kind="Observer" width="55" display="setup">setup</button>
    <chooser x="10" y="95" height="61" variable="shar-stat?" current="2" width="143" display="shar-stat?">
      <choice type="string" value="fuel"></choice>
      <choice type="string" value="missiles"></choice>
      <choice type="string" value="state"></choice>
      <choice type="string" value="mission"></choice>
    </chooser>
    <chooser x="10" y="159" height="61" variable="carrier-stat?" current="1" width="143" display="carrier-stat?">
      <choice type="string" value="name"></choice>
      <choice type="string" value="shars"></choice>
    </chooser>
    <slider x="10" step="1" y="225" max="100" width="250" display="minutes-per-tick" height="50" min="0" direction="Horizontal" default="1.0" variable="minutes-per-tick" units="min"></slider>
    <slider x="10" step="1" y="389" max="10" width="251" display="invincible-cap?" height="50" min="1" direction="Horizontal" default="10.0" variable="invincible-cap?"></slider>
    <slider x="10" step="1" y="335" max="10" width="251" display="hermes-cap?" height="50" min="1" direction="Horizontal" default="8.0" variable="hermes-cap?"></slider>
    <slider x="10" step="1" y="279" max="20" width="250" display="km-per-patch" height="50" min="0" direction="Horizontal" default="2.0" variable="km-per-patch"></slider>
    <monitor x="10" precision="17" y="445" height="60" fontSize="11" width="155" display="Date">current-date-string</monitor>
    <monitor x="170" precision="17" y="445" height="60" fontSize="11" width="100" display="Conflict Days">conflict-days</monitor>
    <switch x="130" y="50" height="40" on="true" variable="show-waypoints?" width="135" display="show-waypoints?"></switch>
    <switch x="270" y="50" height="40" on="true" variable="show-caps?" width="100" display="show-caps?"></switch>
    <chooser x="160" y="160" height="60" variable="spawn-zone" current="4" width="250" display="spawn-zone">
      <choice type="string" value="zone-1"></choice>
      <choice type="string" value="zone-2"></choice>
      <choice type="string" value="zone-3"></choice>
      <choice type="string" value="zone-4"></choice>
      <choice type="string" value="zone-5"></choice>
      <choice type="string" value="TEZ-edge-zone"></choice>
    </chooser>
    <plot x="420" autoPlotX="true" yMax="10.0" autoPlotY="true" yAxis="count" y="865" xMin="0.0" height="245" legend="true" xMax="10.0" yMin="0.0" width="400" xAxis="time" display="UK Boats Hit">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="Frigates Hit" color="-16777216" legend="true">
        <setup></setup>
        <update>plot frigates-hit</update>
      </pen>
      <pen interval="1.0" mode="0" display="Destroyers Hit" color="-7500403" legend="true">
        <setup></setup>
        <update>plot destroyers-hit</update>
      </pen>
      <pen interval="1.0" mode="0" display="Amphibs Hit" color="-2674135" legend="true">
        <setup></setup>
        <update>plot amphibs-hit</update>
      </pen>
      <pen interval="1.0" mode="0" display="Carriers Hit" color="-955883" legend="true">
        <setup></setup>
        <update>plot carriers-hit</update>
      </pen>
    </plot>
    <monitor x="850" precision="17" y="865" height="60" fontSize="11" width="100" display="UK Boats Hit">frigates-hit + destroyers-hit + amphibs-hit + carriers-hit</monitor>
    <monitor x="965" precision="17" y="865" height="60" fontSize="11" width="100" display="Carriers Hit">carriers-hit</monitor>
    <monitor x="965" precision="17" y="940" height="60" fontSize="11" width="100" display="Frigates Hit">frigates-hit</monitor>
    <monitor x="965" precision="17" y="1010" height="60" fontSize="11" width="100">destroyers-hit</monitor>
    <monitor x="965" precision="17" y="1080" height="60" fontSize="11" width="100">amphibs-hit</monitor>
    <monitor x="1570" precision="17" y="875" height="60" fontSize="11" width="100" display="FAA Jets Left">faa-jets</monitor>
    <note x="1560" y="855" backgroundDark="0" fontSize="12" width="215" markdown="false" height="35" textColorDark="-1" textColorLight="-16777216" backgroundLight="0">this monitor is not that helpful</note>
    <plot x="10" autoPlotX="true" yMax="10.0" autoPlotY="true" yAxis="count" y="511" xMin="0.0" height="320" legend="true" xMax="10.0" yMin="0.0" width="410" xAxis="time" display="Air Cover Performance">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="FAA Attacks" color="-13840069" legend="true">
        <setup></setup>
        <update>plot attacks</update>
      </pen>
      <pen interval="1.0" mode="0" display="SHAR Intercepts" color="-13345367" legend="true">
        <setup></setup>
        <update>plot intercepts</update>
      </pen>
      <pen interval="1.0" mode="0" display="Boat Hit" color="-2674135" legend="true">
        <setup></setup>
        <update>plot failures</update>
      </pen>
      <pen interval="1.0" mode="0" display="# FAA Jets" color="-817084" legend="true">
        <setup></setup>
        <update>plot (75 - faa-losses)</update>
      </pen>
      <pen interval="1.0" mode="0" display="Amphibs Landed" color="-10402772" legend="true">
        <setup></setup>
        <update>plot amphibs-landed</update>
      </pen>
    </plot>
    <monitor x="10" precision="17" y="846" height="60" fontSize="11" width="100" display="FAA Sorties Launched">attacks</monitor>
    <monitor x="116" precision="17" y="846" height="60" fontSize="11" width="100" display="FAA losses">faa-losses</monitor>
  </widgets>
  <info>## WHAT IS IT?

(a general understanding of what the model is trying to show or explain)

## HOW IT WORKS

(what rules the agents use to create the overall behavior of the model)

## HOW TO USE IT

(how to use the model, including a description of each of the items in the Interface tab)

## THINGS TO NOTICE

(suggested things for the user to notice while running the model)

## THINGS TO TRY

(suggested things for the user to try to do (move sliders, switches, etc.) with the model)

## EXTENDING THE MODEL

(suggested things to add or change in the Code tab to make the model more complicated, detailed, accurate, etc.)

## NETLOGO FEATURES

(interesting or unusual features of NetLogo that the model uses, particularly in the Code tab; or where workarounds were needed for missing features)

## RELATED MODELS

(models in the NetLogo Models Library and elsewhere which are of related interest)

## CREDITS AND REFERENCES

(a reference to the model's URL on the web if it has one, as well as any other necessary credits, citations, and links)
</info>
