  <linkShapes>
    <shape name="default" curviness="0.0">
      <lines>
        <line x="-0.2" visible="false">
          <dash value="0.0"></dash>
          <dash value="1.0"></dash>
        </line>
        <line x="0.0" visible="true">
          <dash value="1.0"></dash>
          <dash value="0.0"></dash>
        </line>
        <line x="0.2" visible="false">
          <dash value="0.0"></dash>
          <dash value="1.0"></dash>
        </line>
      </lines>
      <indicator>
        <shape name="link direction" rotatable="true" editableColorIndex="0">
          <line endX="90" startY="150" marked="true" color="-1920102913" endY="180" startX="150"></line>
          <line endX="210" startY="150" marked="true" color="-1920102913" endY="180" startX="150"></line>
        </shape>
      </indicator>
    </shape>
  </linkShapes>
  <previewCommands>setup repeat 75 [ go ]</previewCommands>
  <experiments>
    <experiment name="experiment" repetitions="3" sequentialRunOrder="true" runMetricsEveryStep="true">
      <setup>setup</setup>
      <go>go</go>
      <metrics>
        <metric>faa-losses</metric>
        <metric>carriers-hit</metric>
        <metric>frigates-hit</metric>
        <metric>destroyers-hit</metric>
        <metric>amphibs-hit</metric>
        <metric>cur-day</metric>
        <metric>cur-hour</metric>
        <metric>cur-min</metric>
      </metrics>
      <constants>
        <enumeratedValueSet variable="spawn-zone">
          <value value="&quot;zone-1&quot;"></value>
          <value value="&quot;zone-2&quot;"></value>
          <value value="&quot;zone-3&quot;"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="minutes-per-tick">
          <value value="1"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="hermes-cap?">
          <value value="8"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="show-caps?">
          <value value="true"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="km-per-patch">
          <value value="2"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="invincible-cap?">
          <value value="10"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="carrier-stat?">
          <value value="&quot;shars&quot;"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="show-stat?">
          <value value="true"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="shar-stat?">
          <value value="&quot;state&quot;"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="show-waypoints?">
          <value value="true"></value>
        </enumeratedValueSet>
      </constants>
    </experiment>
  </experiments>
</model>
