;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; ENEMY DETECTION
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to detect-british

  if any? british-troops [

    let enemy min-one-of british-troops [distance myself]

    if distance enemy <= 4 [
      set target enemy
      face enemy
    ]

    if distance enemy > 4 [
      set target nobody
    ]

  ]

end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; COMBAT
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to fire-at-target

  if target = nobody [ stop ]

  let dist distance target
  let hit-prob 0.25
  set hit-prob hit-prob + hit-prob * 1 / dist

  ;; entrenched defenders shoot better
  if entrenched? [
    set hit-prob hit-prob + 0.10
  ]

  if random-float 1 < hit-prob [
    ask target [
      set strength strength - lethality
    ]
  ]

end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; ARGENTINE RETREAT
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to retreat

  set entrenched? false
  set target nobody

  rt random 360

  ; if [terrain] of patch-ahead 1 != "water" [
  ;   fd 1
  ; ]
  ; water is white
  ; if [pcolor] of patch-ahead 1 != [255 255 255] [
  ;   fd 1
  ; ]

end