;;   [COMMENTED OUT - no per-tick snapshot export needed]
;; end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; SHIP MANAGEMENT & NGFS SUPPORT
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to update-ship-status
  ;; Check if any ships were destroyed at current tick
  ;; ships-data format: [id x y destruction-datetime-string]
  ;; For now, use a simplified check: if destruction datetime matches current date/time, remove ship
  
  ;; TODO: Parse destruction datetime and compare with current date/time
  ;; For this iteration, assume destruction times are provided and we need to check them
  ;; This is a placeholder for full datetime comparison logic
end

to-report get-living-ship-count
  ;; Return count of ships still alive
  report length ships-alive
end

to-report get-dynamic-ngfs-interval
  ;; Base interval: ngfs-base-fire-interval
  ;; Penalty: +2 ticks per lost ship from original complement (max 13)
  let living-count get-living-ship-count
  let dead-count (13 - living-count)
  
  let penalty dead-count * 2
  report ngfs-base-fire-interval + penalty
end

to-report get-random-living-ship
  ;; Return a random ship ID from ships-alive list, or nobody if none left
  if length ships-alive = 0 [ report nobody ]
  report one-of ships-alive
end

to-report get-ship-position [ship-id]
  ;; Find ship in ships-data by ID and return [x y]
  ;; Format: [id x y destruction-datetime-string]
  foreach ships-data [ ship ->
    if item 0 ship = ship-id [
      report (list (item 1 ship) (item 2 ship))
    ]
  ]
  report false
end  

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; MAIN LOOP
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; ─────────────────────────────────────────────────────────────
;; One tick of battle logic
;; ─────────────────────────────────────────────────────────────
to go-step
  advance-time 90  ;; Advance 90 minutes (1.5 hours) per tick
  update-date-string
  update-ship-status
  
  refresh-patch-visuals
  run-argentine-troops
  run-british-troops
  run-ngfs-phase
  tick
end;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; BATTLE SIMULATION CONTROL
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; ─────────────────────────────────────────────────────────────
;; Battle termination reporters
;; ─────────────────────────────────────────────────────────────
to-report ground-trial-done?
  ;; Trial ends when either side has no remaining agents
  if not any? british-troops   [ report true ]
  if not any? argentine-troops [ report true ]
  report false
end

to-report simulation-over?
  ;; Alias for ground-trial-done? (for backward compatibility)
  report ground-trial-done?
end

to-report british-win?
  ;; Britain wins when no Argentine troops remain
  report not any? argentine-troops
end

;; ─────────────────────────────────────────────────────────────
;; Run one complete battle from start to finish
;; ─────────────────────────────────────────────────────────────
to run-battle
  ;; setup has already been called
  ;; Just loop until battle is over
  while [not simulation-over?] [
    go-step
  ]
  
  ;; Battle complete — output results
  output-final-results
end

;; ─────────────────────────────────────────────────────────────
;; Main entry point (from NetLogo GUI or test harness)
;; Test harness calls: while [not ground-trial-done?] [ go ]
;; Automatically exports results when trial ends
;; ─────────────────────────────────────────────────────────────
to go
  ;; Execute one tick of the battle
  if not ground-trial-done? [
    go-step
  ]
  
  ;; Automatically export results when trial ends (works for both GUI and harness)
  if ground-trial-done? and not trial-exported? [
    output-final-results
    set trial-exported? true
  ]
end

