<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[__includes [
  "utils/datetime.nls"
  "utils/test_harness.nls"
  "turtles/ground/argentine_model.nls"
  "turtles/ground/british_model.nls"
  "turtles/ground/ngfs_model.nls"
]

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; VARIABLES
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

globals [
  ;; Trial Metadata
  trial-id
  trial-seed-ground           ;; separate seed for ground battle RNG
  
  ;; DateTime Tracking (from utils/datetime.nls)
  cur-min cur-hour cur-day cur-month cur-year
  current-date-string
  
  ;; Harness Inputs (DataClass GroundInputs)
  ground-battle               ;; str: start date (e.g., "May 21 1982 - 00:00")
  air-battle-end              ;; str: when air battle ended (constrains unit spawning)
  amphibs-landed              ;; int: determines the number of british troops to spawn
  ship-coords                 ;; str: JSON-like string of ship coordinates
  
  ;; Harness Outputs (DataClass GroundOutputs)
  ground-battle-end           ;; str: end date string
  conflict-days               ;; float: duration in days
  british-kia                 ;; int: total British killed
  argentine-kia               ;; int: total Argentine killed
;   also surrenders-total from Analytics: Troop Outcomes (below)
  
  ;; Internal Metadata & Tracking
  ground-battle-start-string  ;; intermediate storage for parsed start
  
  ;; Naval Gunfire Support (based on remaining ships from air battle)
  ngfs-enabled?
  ngfs-base-fire-interval     ;; base interval when all ships present
  ngfs-dispersion-radius
  ngfs-mode   
  ngfs-ship-range             ;; range per ship (15 patches)
  ngfs-last-fire-tick
  
  ;; Ship Availability (input from air battle outcomes)
  destroyers-remaining-input  ;; deprecated, kept for safety
  frigates-remaining-input    ;; deprecated, kept for safety
  ships-alive                 ;; list of ship IDs still active
  ships-data                  ;; ship metadata: [id x y destruction-datetime-string]
  
  ;; Configuration: Damage & Effects
  trench-damage-mult
  bunker-damage-mult
  bunker-suppression-mult
  ngfs-suppression-ticks

  ;; Configuration: Bunkers & Units
  bunker-mode
  bunker-default-capacity

  ;; Configuration: Simulation Controls
  suppression-enabled?
  surrender-enabled?
  show-heatmap?
  historical-spawn?           ;; if true, spawn Argentine units at historical positions

  ;; State: NGFS Runtime
  ngfs-strikes
  ngfs-total-damage
  ngfs-total-kills
  ngfs-last-strike-x
  ngfs-last-strike-y
  ngfs-open-exposures
  ngfs-trench-exposures
  ngfs-bunker-exposures

  ;; Analytics: Bunkers & Casualties
  bunkers-destroyed
  bunker-entries-total

  ;; Analytics: Troop Outcomes
  surrenders-total
  arg-strength-loss-total
  panic-events-total
  suppression-events-total

  ;; Analytics: Casualties (tracked for test harness output)
  british-casualties          ;; total British units killed
  argentine-casualties        ;; total Argentine units killed

  ;; Debug: track max ticks-stuck ever seen
  debug-max-stuck
  debug-escape-count
  
  ;; Output CSV
  results-file
  trial-exported?             ;; flag to track if results have been exported for this trial
  
  ;; Troop Tracking
  british-battalions-spawned  ;; count of British units that actually spawned
]

patches-own [
  ;; Terrain
  elevation-level
  water?
  base-pcolor

  ;; Fortifications
  bunker?
  trench?
  bunker-strength
  bunker-capacity

  ;; NGFS Tracking
  strike-count
  ngfs-flash-ticks
]

breed [argentine-troops argentine-troop]
breed [british-troops british-troop]

turtles-own [
  ;; Combat Stats
  strength
  morale

  ;; Cover State
  entrenched?
  in-bunker?
  bunker-target

  ;; Combat Engagement
  engagement-target

  ;; Behavioral State
  suppressed-ticks
  panic-move?
]

british-troops-own [
  ;; Movement & Combat Profile
  mobility
  lethality
  engagement-distance
  max-accuracy-distance
  invulnerability
  unit-type

  ;; Behavioral State
  status
  retreat-threshold

  ;; Pathfinding
  ticks-stuck
  recent-patches  ;; list of patches visited in last 3 ticks (breadcrumb)
]

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; SETUP
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to setup
  ;clear-all
  
  ;; Seed RNG per trial (use trial-seed-ground if set, else trial-id)
  if not is-number? trial-seed-ground [ set trial-seed-ground trial-id ]
  random-seed trial-seed-ground

  ;; Parse ground battle start datetime (format: "May 21 1982 - 00:00")
  parse-ground-battle-start-date
  
  ;; Initialize conflict tracking
  set conflict-days 0
  update-date-string
  
  ;; Initialize analytics counters and dummy data (must run before ship initialization)
  initialize-global-state
  
  ;; Initialize ship availability from air battle outcomes (or fallback to dummy data)
  initialize-ships-from-air-battle
  
  ;; Initialize terrain and fortifications
  initialize-patch-state
  
  ;; Spawn troops based on available units
  initialize-troop-state
  
  reset-ticks
end

to initialize-global-state
  ;; Configuration: Damage & Effects (initialize if not set)
  if not is-number? trench-damage-mult [ set trench-damage-mult 0.5 ]
  if not is-number? bunker-damage-mult [ set bunker-damage-mult 0.3 ]
  if not is-number? bunker-suppression-mult [ set bunker-suppression-mult 2.0 ]
  if not is-number? ngfs-suppression-ticks [ set ngfs-suppression-ticks 5 ]
  
  ;; Configuration: Simulation Controls (initialize booleans)
  if suppression-enabled? != true and suppression-enabled? != false [ set suppression-enabled? true ]
  if surrender-enabled? != true and surrender-enabled? != false [ set surrender-enabled? true ]
  if show-heatmap? != true and show-heatmap? != false [ set show-heatmap? false ]
  if historical-spawn? != true and historical-spawn? != false [ set historical-spawn? true ]
  
  ;; NGFS runtime state
  set ngfs-last-fire-tick 0

  ;; Analytics: NGFS
  set ngfs-strikes 0
  set ngfs-total-damage 0
  set ngfs-total-kills 0
  set ngfs-last-strike-x 0
  set ngfs-last-strike-y 0
  set ngfs-open-exposures 0
  set ngfs-trench-exposures 0
  set ngfs-bunker-exposures 0

  ;; Analytics: Bunkers & Casualties
  set bunkers-destroyed 0
  set bunker-entries-total 0

  ;; Analytics: Troop Outcomes
  set surrenders-total 0
  set arg-strength-loss-total 0
  set panic-events-total 0
  set suppression-events-total 0

  ;; Analytics: British Casualties
  set british-casualties 0
  
  ;; CSV Export tracking
  set trial-exported? false

  ;; NGFS Ship Data — dummy positions for ship-based targeting
  set ships-data [
    [1 -16 6]    ;; Ship 1 at west coast north
    [2 -16 2]    ;; Ship 2 at west coast center
    [3 16 6]     ;; Ship 3 at east coast north
    [4 15 8]     ;; Ship 4 at northeast offshore
  ]

  ;; Debug trackers
  set debug-max-stuck 0
  set debug-escape-count 0
  
  ;; Close any stray file handles
  carefully [ file-close-all ] []
end

to initialize-patch-state
  import-pcolors "terrain_map.png"

  ;; Initialize configuration defaults if not set
  if bunker-mode != "historical" and bunker-mode != "random" [ set bunker-mode "historical" ]
  if not is-number? bunker-default-capacity [ set bunker-default-capacity 1 ]

  ask patches [
    set base-pcolor pcolor
    set bunker? false
    set trench? false
    set bunker-strength 0
    set bunker-capacity 1
    set water? false
    set strike-count 0
    set ngfs-flash-ticks 0
    set plabel ""
  ]

  assign-elevation
  classify-water
  setup-bunkers
  refresh-patch-visuals
end

to initialize-troop-state
  ;; Only spawn Argentine troops (no specific spawn logic yet)
  spawn-argentine-battalions
  ask argentine-troops [
    update-visual-state
  ]
  
  ;; Spawn British troops, filtering by available battalions
  if not is-number? amphibs-landed or amphibs-landed = 0 [ set amphibs-landed 10 ]
  spawn-british-troops-filtered
  
  ;; Track how many British troops actually spawned (for kill count calculation)
  set british-battalions-spawned count british-troops
end

to spawn-british-troops-filtered
  ;; Five task forces land on the western coast (San Carlos area)
  ;; Positions are scaled to the v2 world (-16 to 16)
  ;; All units spawn (filtering by air battle is handled upstream)
  
  let initial-british-positions [
    [-14  7]  ;; SBS (index 0)
    [-12  6]  ;; 3 Para (index 1)
    [-14  1]  ;; 40 Commando (index 2)
    [-13 -1]  ;; 2 Para (index 3)
    [-15  0]  ;; 45 Commando (index 4)
    [-14  7]  ;; SBS (index 0)
    [-12  6]  ;; 3 Para (index 1)
    [-14  1]  ;; 40 Commando (index 2)
    [-13 -1]  ;; 2 Para (index 3)
    [-15  0]  ;; 45 Commando (index 4)
  ]

  let i amphibs-landed
  foreach initial-british-positions [ pos ->
    let px item 0 pos
    let py item 1 pos
    ifelse i < 1 [ stop ][ set i i - 1 ] ;; ensures troops are only spawned if their ship landed
    
    ;; If the target patch is water, find the nearest non-water alternative
    let dest-patch patch px py
    if [water?] of dest-patch [
      set dest-patch min-one-of patches with [not water? and pxcor < -5] [
        distancexy px py
      ]
    ]
    
    if dest-patch != nobody [
      create-british-troops 1 [
        move-to dest-patch
        set color red
        set size 2
        set shape "default"

        ;; Combat profile (SCALED FOR 84 TICKS)
        set mobility            5
        set lethality           7.5  ;; reduced from 30
        set engagement-distance 7
        set max-accuracy-distance 4
        set invulnerability     0
        set unit-type           "infantry"

        ;; Behavioral state (turtles-own)
        set strength            100
        set morale              100
        set entrenched?         false
        set in-bunker?          false
        set bunker-target       nobody
        set engagement-target   nobody
        set suppressed-ticks    0
        set panic-move?         false

        ;; Pathfinding
        set ticks-stuck 0
        set recent-patches []
        set status              "advance"
        set retreat-threshold   30
      ]
    ]
  ]
end



;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; TERRAIN
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to assign-elevation
  ask patches [
    if pcolor <= 20 [ set elevation-level 0 ]
    if pcolor > 20 and pcolor <= 60 [ set elevation-level 1 ]
    if pcolor > 60 [ set elevation-level 2 ]
  ]
end

to classify-water
  ask patches [
    if pcolor = white or pcolor = black [
      set water? true
    ]
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; BUNKERS (LIMITED TO 5)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to setup-bunkers

  ask patches [
    set bunker? false
    set bunker-strength 0
    set bunker-capacity bunker-default-capacity
    set plabel ""
  ]

  ifelse bunker-mode = "historical" [
    ;; Historical mode: place bunkers at fixed coordinates
    let historical-bunker-coords [[10 2] [12 -4] [8 -8] [11 0] [9 -6]]
    foreach historical-bunker-coords [ coord ->
      let b-patch patch (item 0 coord) (item 1 coord)
      if b-patch != nobody and not [water?] of b-patch [
        ask b-patch [
          set bunker? true
          set bunker-strength 100
          set bunker-capacity 1
          set pcolor black
          set plabel "B"
          set plabel-color white
        ]
      ]
    ]
  ] [
    ;; Random mode: select random high-ground patches in east
    let candidates patches with [not water?]
    if any? candidates [
      ask n-of (min list 5 count candidates) candidates [
        set bunker? true
        set bunker-strength 100
        set bunker-capacity 1
        set pcolor black
        set plabel "B"
        set plabel-color white
      ]
    ]
  ]

end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; VISUALS
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to refresh-patch-visuals
  ask patches [

    if ngfs-flash-ticks > 0 [
      set pcolor red
      set ngfs-flash-ticks ngfs-flash-ticks - 1
    ]

    if ngfs-flash-ticks = 0 [

      if bunker? [
        set pcolor black
        set plabel "B"
        set plabel-color white
      ]

      if trench? and not bunker? [
        set pcolor brown
        set plabel ""
      ]

      if not bunker? and not trench? [
        if (is-boolean? show-heatmap? and show-heatmap?) and strike-count > 0 and not water? [
          set pcolor scale-color red strike-count 0 20
        ]
        if not ((is-boolean? show-heatmap? and show-heatmap?) and strike-count > 0 and not water?) [
          set pcolor base-pcolor
        ]
        set plabel ""
      ]
    ]
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; COAST
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to-report is-coastal? [p]
  let nearby [neighbors4] of p
  report any? nearby with [water?]
end

to-report distance-to-coast [p]
  let coast patches with [is-coastal? self]
  if not any? coast [ report 999 ]
  report min [distance p] of coast
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; DATA EXPORT (CSV OUTPUT)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; ─────────────────────────────────────────────────────────────
;; Export current battle results to CSV (call explicitly after trial ends)
;; ─────────────────────────────────────────────────────────────
to export-results
  ;; User-callable wrapper for output-final-results
  output-final-results
end

to output-final-results
  ;; Write final battle results to CSV
  ;; Following GroundOutputs dataclass: ground_battle_end, conflict_days, british_kia, argentine_kia
  
  ;; Set the specific harness output variables
  set ground-battle-end current-date-string
  set conflict-days (ticks * 0.125)
  
  set british-kia (british-battalions-spawned - count british-troops)
  set argentine-kia ngfs-total-kills
  
  ;; Sync with result-line for CSV
  let british-killed british-kia
  let argentine-killed argentine-kia
  let duration-days conflict-days
  
  ;; Outcome: 1 if British win (all Argentine dead), 0 otherwise
  let outcome ifelse-value (not any? argentine-troops) [ 1 ] [ 0 ]
  
  ;; Argentine surrendered: already tracked
  let argentine-surrendered surrenders-total
  
  ;; Write to results CSV
  set results-file "output/battle_results.csv"
  
  ;; Build result line
  let result-line (word
    trial-id ","
    ground-battle-start-string ","
    ground-battle-end ","
    duration-days ","
    british-killed ","
    argentine-killed ","
    argentine-surrendered ","
    outcome
  )
  
  carefully [
    ;; Read all existing content to memory
    let existing-lines []
    if file-exists? results-file [
      file-open results-file
      while [not file-at-end?] [
        set existing-lines lput file-read-line existing-lines
      ]
      file-close
    ]
    
    ;; Overwrite the file from scratch
    if file-exists? results-file [ file-delete results-file ]
    file-open results-file
    
    let header-row "trial_id,ground_battle_start,ground_battle_end,duration_days,british_killed,argentine_killed,argentine_surrendered,outcome"
    
    ;; Write header if it's a new file or doesn't have one
    ifelse length existing-lines = 0 [
      file-print header-row
    ] [
      ;; Write existing lines
      foreach existing-lines [ line ->
        file-print line
      ]
    ]
    
    ;; Append the new result
    file-print result-line
    file-close
    
    show (word "[CSV EXPORT] Results written to " results-file)
  ] [
    show (word "[CSV EXPORT ERROR] Failed to write to " results-file ". Check that output/ directory exists and is writable.")
  ]
  
  show (word "[BATTLE COMPLETE] Trial " trial-id 
    " | Duration: " duration-days " days"
    " | British units killed: " british-killed
    " | Argentine units killed: " argentine-killed
    " | Argentine units surrendered: " argentine-surrendered
    " | Outcome: " outcome)
end

;; ─────────────────────────────────────────────────────────────
;; COMMENTED OUT: Old diagnostic CSV export code
;; ─────────────────────────────────────────────────────────────

;; to write-snapshot-header
;;   file-open export-file
;;   file-print "tick,bunker_mode,ngfs_mode,range,interval,strikes,total_damage,total_kills,surrenders,total_strength_loss,troops_remaining,avg_strength,avg_morale,min_morale,troops_on_ridge,bunkers_remaining,bunkers_destroyed,trench_patches,troops_in_bunkers,troops_in_trenches,suppressed_troops,bunker_entries,panic_events,suppression_events,ngfs_open_exposures,ngfs_trench_exposures,ngfs_bunker_exposures,avg_detection_range,avg_hit_prob,last_x,last_y"
;;   file-close
