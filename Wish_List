import pandas as pd
import matplotlib.pyplot as plt

# Load data
df = pd.read_csv("experiment-output.csv")

# Compute summary stats
print("Mean win probability:", df["final-p"].mean())
print("Mean duration:", df["final-duration-mean"].mean())

# Plot carrier distance vs win probability
plt.scatter(df["carrier-distance"], df["final-p"])
plt.xlabel("Carrier Distance")
plt.ylabel("British Win Probability")
plt.title("Win Probability vs Carrier Distance")
